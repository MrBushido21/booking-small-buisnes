# Шаблон окружения. Скопируй в .env и подставь свои значения:
#   cp .env.example .env
#
# Сам .env в git не попадает (см. .gitignore) — в этом файле НЕ ДОЛЖНО быть
# настоящих секретов, только плейсхолдеры.

# --- Приложение ---
PORT=3000
# Адрес фронта: используется в ссылках из писем (например, сброс пароля)
FRONTEND_URL=http://localhost:5173

# --- Postgres ---
# Локально (npm run dev) — localhost.
# В docker compose приложение ходит к контейнеру по имени сервиса: POSTGRES_HOST=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=freelance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# --- Redis (кэш слотов, идемпотентность, очередь писем) ---
# В docker compose: REDIS_HOST=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# --- JWT ---
# Минимум 16 символов, иначе приложение не стартует (см. src/env.validation.ts).
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# access и refresh должны быть РАЗНЫМИ: иначе refresh-токен примут как access.
JWT_ACCESS_SECRET=replace-with-32-byte-random-hex
JWT_REFRESH_SECRET=replace-with-another-32-byte-random-hex

# --- Почта ---
# Локально письма ловит mailpit из docker-compose: SMTP на 1025, веб-морда на http://localhost:8025
# В docker compose: SMTP_HOST=mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=noreply@example.com
