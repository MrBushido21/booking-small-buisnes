# Что НЕ должно попасть в образ.
# Без этого файла `COPY . .` утащит в слой .env с секретами — а слои образа
# читает любой, у кого есть образ, даже если файл удалить следующей командой.
.env
.env.*
!.env.example
*.env.bak

# Ставится внутри через npm ci: хостовые модули могут быть собраны под другую ОС
node_modules
dist
build
coverage

.git
.gitignore
.vscode
.idea

# Пользовательские загрузки — это данные, а не код (в контейнере том)
uploads/*
!uploads/.gitkeep

# Внутренние документы
ТЗ.md
API.md

Dockerfile
.dockerignore
docker-compose.yml
*.log
